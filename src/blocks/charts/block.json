{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "dcx-benchmark-luxe/charts",
  "version": "1.0.0",
  "title": "DCX Charts",
  "category": "common",
  "icon": "chart-bar",
  "description": "Graphique de données en barres horizontales ou camembert, avec insight et modale.",
  "keywords": ["dcx", "chart", "bar", "pie", "graphique", "benchmark"],
  "textdomain": "dcx-benchmark-luxe",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php",
  "attributes": {
    "title": {
      "type": "string",
      "default": ""
    },
    "titleFontSize": {
      "type": "string",
      "default": ""
    },
    "items": {
      "type": "array",
      "default": [
        { "label": "Entrée 1", "value": 60 },
        { "label": "Entrée 2", "value": 40 }
      ]
    },
    "chartType": {
      "type": "string",
      "default": "bar",
      "enum": ["bar", "pie"]
    },
    "insightText": {
      "type": "string",
      "default": ""
    },
    "modalBody": {
      "type": "string",
      "default": ""
    },
    "valueSuffix": {
      "type": "string",
      "default": "%"
    },
    "xMax": {
      "type": "number",
      "default": 100
    }
  },
  "supports": {
    "html": false,
    "align": true,
    "color": {
      "background": false,
      "text": false
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "__experimentalDefaultControls": { "padding": true, "margin": false }
    },
    "shadow": true,
    "__experimentalBorder": {
      "color": true,
      "radius": true,
      "width": true,
      "style": true,
      "__experimentalDefaultControls": {
        "color": true,
        "radius": true,
        "width": true,
        "style": true
      }
    }
  }
}
